{
  "manifest_version": 3,
  "name": "ChatGPT Reading Assistant",
  "version": "0.1.0",
  "description": "Enhance ChatGPT reading experience with selection toolbar, citation clipboard, and more.",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "utils/storage.js",
        "utils/event-bus.js",
        "utils/events.js",
        "utils/ui-helpers.js",
        "utils/markdown.js",
        "content/core/dom.js",
        "content/core/registry.js",
        "content/modules/message-scanner.js",
        "content/modules/input-integration.js",
        "content/modules/selection-tracker.js",
        "content/modules/selection-toolbar.js",
        "content/modules/citation-clipboard.js",
        "content/core/runtime-handler.js",
        "content/core/spa-observer.js",
        "content/core/bootstrap.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
